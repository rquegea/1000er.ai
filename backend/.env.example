DETECTION_NMS_IOU_THRESHOLD=0.45
MOSAIC_CELL_SIZE=150
MOSAIC_COLUMNS=8
MOSAIC_PADDING=4
MOSAIC_MAX_CROPS=80
GEMINI_V2_TEMPERATURE=0.2
DEBUG_DETECTION=false
